# ── AI ─────────────────────────────────────────────────────────────────────────
# Google Gemini API key — https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ── YouTube ─────────────────────────────────────────────────────────────────────
# YouTube Data API v3 key — https://console.cloud.google.com
YOUTUBE_API_KEY=

# ── Channels ────────────────────────────────────────────────────────────────────
# Comma-separated YouTube handles to track (competitors + your own)
TRACKED_HANDLES=@handle1,@handle2,@yourChannel

# Your own channel handles (subset of TRACKED_HANDLES) — marked "YOURS" in UI
OWN_HANDLES=@yourChannel

# Short description of your niche — used in AI prompts
CHANNEL_NICHE=NEET/Medical Education

# ── Database ────────────────────────────────────────────────────────────────────
# Upstash Redis — required for Vercel deployment (data persists across cold starts)
# Create a free database at https://console.upstash.com
# Copy the REST URL and token from: Database → REST API tab
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Leave UPSTASH vars blank for local dev — falls back to .local-db/ JSON files
